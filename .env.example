# ── Deployment ─────────────────────────────────────────────
# Private key for deploying contracts to testnet/mainnet
# DO NOT commit your real key — .env is gitignored
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── App Config (shared by Vite frontend + deploy scripts) ──
VITE_PRIVY_APP_ID=
VITE_CHAIN_ID=
VITE_RPC_URL=

# ── Redis (indexer + server) ───────────────────────────────
# REDIS_URL=redis://127.0.0.1:6379

# ── Local Development (populate script) ────────────────────
# CONTRACT_ADDRESS=          # Skip deploy in populate script, use existing contract
# DEADLINE_OFFSET=3600       # Deadline offset in seconds
