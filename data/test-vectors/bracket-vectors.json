  "validationTests": [
    { "hex": "0xffffffffffffffff", "valid": true, "reason": "all bits set including sentinel" },
    { "hex": "0x8000000000000000", "valid": true, "reason": "sentinel only, all team2 wins" },
    { "hex": "0xbfffffffbfffbfba", "valid": true, "reason": "cinderella bracket, sentinel set" },
    { "hex": "0x7fffffffffffffff", "valid": false, "reason": "MSB not set — missing sentinel" },
    { "hex": "0x0000000000000000", "valid": false, "reason": "all zeros — no sentinel" },
    { "hex": "0x1234567890abcdef", "valid": false, "reason": "first nibble 0x1 < 0x8 — no sentinel" }
